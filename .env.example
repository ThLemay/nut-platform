# Copy this file to .env and fill in real values. Never commit the real .env.

# Environment: development | staging | production
ENV=development

# Async PostgreSQL DSN. In docker-compose, host=db. For local dev: localhost.
DATABASE_URL=postgresql+asyncpg://nut_user:CHANGE_ME@db:5432/nut_dev

# JWT signing secret. Generate with: openssl rand -hex 48
SECRET_KEY=CHANGE_ME

# ID of the NUT organization (legal owner of containers)
NUT_ORG_ID=1

# PostgreSQL container creds (consumed by docker-compose.yml)
POSTGRES_USER=nut_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=nut_dev

# pgAdmin (only used in dev compose stack)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME
